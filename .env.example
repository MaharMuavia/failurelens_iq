# FailureLens IQ configuration sample.
# Copy to .env for production-like local runs and fill secrets outside Git.

AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_API_KEY=
AZURE_AI_AGENT_NAME=FailureLensIQAgent
AZURE_AI_MODEL_DEPLOYMENT_NAME=grok-4-20-reasoning
FOUNDRY_CALL_MODE=mock
AZURE_AUTH_MODE=api_key
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

APP_MODE=demo
IQ_PROVIDER=local
IQ_MODE=local
MODEL_PROVIDER=foundry_openai
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_OPENAI_BASE_URL=
FOUNDRY_API_KEY=
FOUNDRY_MODEL_DEPLOYMENT=
FOUNDRY_AGENT_NAME=
FOUNDRY_AGENT_VERSION=1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MICROSOFT_IQ_MODE=foundry_adapter_ready
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
CORS_CREDENTIALS=true
CORS_METHODS=*
CORS_HEADERS=*

ENABLE_AUTH=false
API_KEY=change-me-for-production

MAX_UPLOAD_BYTES=1048576
REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_MAX_KEYS=10000
TRUST_PROXY_HEADERS=false
DEMO_CACHE_TTL_SECONDS=300
VIDEO_DEMO_MODE=false
AZURE_MAX_DOCS_TO_INDEX=200
AZURE_MAX_CHUNK_CHARS=1800
AZURE_MAX_SEARCH_TOP_K=5
AZURE_OPENAI_MAX_TOKENS=500
AZURE_OPENAI_TEMPERATURE=0.2
ENABLE_AZURE_TRACE_STORAGE=false
ENABLE_AZURE_REPORT_UPLOAD=false

REPORT_OUTPUT_DIR=reports
KNOWLEDGE_DIR=knowledge/foundry_docs
FOUNDRY_IQ_KNOWLEDGE_DIR=knowledge/foundry_docs
UPLOAD_STORE_PATH=data/uploads/uploaded_experiments.json

# Microsoft Foundry IQ Configuration
# IQ_MODE can be "local" or "azure". Local mode runs the Foundry-compatible
# TF-IDF grounding adapter with no Azure dependencies.

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_KEY=
AZURE_AI_SEARCH_INDEX=failurelens-knowledge

AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=failurelens-iq

AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE=failurelens
AZURE_COSMOS_CONTAINER=reasoning_traces

VITE_API_BASE_URL=http://localhost:8000
VITE_PROXY_TARGET=http://api:8000
VITE_DEMO_API_KEY=
VITE_VIDEO_DEMO_MODE=false
