# Real Azure / Foundry IQ mode. Copy to .env or .env.azure and fill values locally.

APP_MODE=production
IQ_PROVIDER=azure_foundry

HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true
CORS_METHODS=*
CORS_HEADERS=*

AZURE_AI_SEARCH_ENDPOINT=https://YOUR-SEARCH-SERVICE.search.windows.net
AZURE_AI_SEARCH_KEY=YOUR_SEARCH_ADMIN_KEY
AZURE_AI_SEARCH_INDEX=failurelens-knowledge

AZURE_OPENAI_ENDPOINT=https://YOUR-AZURE-OPENAI-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_KEY
AZURE_OPENAI_DEPLOYMENT=YOUR_DEPLOYMENT_NAME

AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE=failurelens
AZURE_COSMOS_CONTAINER=reasoning_traces

AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=failurelens-iq

ENABLE_AUTH=false
API_KEY=change-me-if-auth-enabled
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_BYTES=1048576
REQUEST_TIMEOUT_SECONDS=30
DEMO_CACHE_TTL_SECONDS=300

AZURE_MAX_DOCS_TO_INDEX=200
AZURE_MAX_CHUNK_CHARS=1800
AZURE_MAX_SEARCH_TOP_K=5
AZURE_OPENAI_MAX_TOKENS=500
AZURE_OPENAI_TEMPERATURE=0.2
ENABLE_AZURE_TRACE_STORAGE=false
ENABLE_AZURE_REPORT_UPLOAD=false

REPORT_OUTPUT_DIR=reports
KNOWLEDGE_DIR=knowledge/foundry_docs
UPLOAD_STORE_PATH=data/uploads/uploaded_experiments.json

VITE_API_BASE_URL=http://localhost:8000
VITE_PROXY_TARGET=http://api:8000
VITE_DEMO_API_KEY=
VITE_VIDEO_DEMO_MODE=true
