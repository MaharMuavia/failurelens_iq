# ==================== APP CONFIGURATION ====================
APP_MODE=demo                              # "demo" or "production"
IQ_PROVIDER=local                          # "local" or "azure_foundry"
LOG_LEVEL=INFO                             # DEBUG, INFO, WARNING, ERROR, CRITICAL
REPORT_OUTPUT_DIR=reports                  # Where to save markdown reports

# ==================== LOCAL DEMO MODE ====================
# No credentials needed below for demo mode
KNOWLEDGE_DIR=knowledge/foundry_docs       # Local knowledge base directory

# ==================== AZURE OPENAI (Optional - Production) ====================
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4              # Deployment name in your resource

# ==================== AZURE AI SEARCH (Optional - Production) ====================
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_KEY=
AZURE_AI_SEARCH_INDEX=ml_experiments       # Index name for experiment knowledge

# ==================== AZURE BLOB STORAGE (Optional - Production) ====================
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=failurelens-iq        # Container for experiment artifacts

# ==================== AZURE COSMOS DB (Optional - Production) ====================
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE=failurelens
AZURE_COSMOS_CONTAINER=reasoning_traces    # Container for analysis history

# ==================== FASTAPI SETTINGS ====================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ==================== CORS SETTINGS ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true
CORS_METHODS=*
CORS_HEADERS=*
